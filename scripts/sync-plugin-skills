#!/usr/bin/env python3
from __future__ import annotations

import shutil
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
SOURCE = ROOT / "skills"
TARGETS = [
    ROOT / "plugins" / "sadlay-skills" / "skills",
    ROOT / "plugins" / "codex-sadlay-skills" / "skills",
]
def copy_skills() -> list[str]:
    skill_dirs = sorted(path for path in SOURCE.iterdir() if (path / "SKILL.md").exists())
    names = [path.name for path in skill_dirs]

    for target in TARGETS:
        if target.exists():
            shutil.rmtree(target)
        target.mkdir(parents=True, exist_ok=True)
        for skill_dir in skill_dirs:
            shutil.copytree(skill_dir, target / skill_dir.name)

    return names


def main() -> int:
    if not SOURCE.exists():
        raise SystemExit("skills/ directory does not exist")
    names = copy_skills()
    print(f"Synced {len(names)} skill(s) into plugin packages.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
